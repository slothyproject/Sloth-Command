# Central Command API — REST Client test file
# Requires: humao.rest-client extension
# Usage: click "Send Request" above any request block

@baseUrl = http://localhost:3001
@prodUrl = https://central-hub-api-production.up.railway.app

# ── Set this after logging in ────────────────────────────────────────────────
@token = YOUR_JWT_TOKEN_HERE

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "password": "central-hub-2025"
}

### Health check
GET {{baseUrl}}/api/health

### List services
GET {{baseUrl}}/api/services
Authorization: Bearer {{token}}

### Get variables for a service
GET {{baseUrl}}/api/services/{{serviceId}}/variables
Authorization: Bearer {{token}}

### Get variables (reveal secrets)
GET {{baseUrl}}/api/services/{{serviceId}}/variables?reveal=1
Authorization: Bearer {{token}}

### Save a secret variable
PUT {{baseUrl}}/api/services/{{serviceId}}/variables
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "MY_SECRET",
  "value": "super-secret-value",
  "isSecret": true,
  "category": "api"
}

### Recent audit logs
GET {{baseUrl}}/api/audit-logs?limit=20
Authorization: Bearer {{token}}

### Audit logs for a specific service
GET {{baseUrl}}/api/audit-logs?resourceType=service&resourceId={{serviceId}}
Authorization: Bearer {{token}}

### Deploy a Railway service
POST {{baseUrl}}/api/railway/services/{{railwayServiceId}}/deploy
Authorization: Bearer {{token}}

### Restart a Railway service
POST {{baseUrl}}/api/railway/services/{{railwayServiceId}}/restart
Authorization: Bearer {{token}}

### Sync Railway services
POST {{baseUrl}}/api/railway/sync
Authorization: Bearer {{token}}

### AI chat
POST {{baseUrl}}/api/ai/chat
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "message": "What services are currently unhealthy?",
  "sessionId": "test-session"
}

### AI analyze a service
POST {{baseUrl}}/api/ai/analyze/{{serviceId}}
Authorization: Bearer {{token}}
