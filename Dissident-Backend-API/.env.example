# Discord OAuth Configuration
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=https://dissident-website-production.up.railway.app/api/auth/discord/callback
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# JWT Configuration
JWT_SECRET=your_random_jwt_secret_here_min_32_chars

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dissident

# Frontend URL
FRONTEND_URL=https://dissident-website-production.up.railway.app

# Server Configuration
PORT=3000
NODE_ENV=production

# Optional: UXMagic Analytics
UXMAGIC_API_KEY=your_uxmagic_api_key_here
