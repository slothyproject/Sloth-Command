# ── Discord Bot ────────────────────────────────────────────────
DISSIDENT_TOKEN=your_discord_bot_token_here

# ── Discord OAuth (for web login) ──────────────────────────────
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://dissident:password@localhost:5432/dissident_hub

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Web Panel ──────────────────────────────────────────────────
SECRET_KEY=generate-a-32-char-random-secret-key-here
ADMIN_USER=admin
ADMIN_PASS=change-this-password

# ── Feature flags ──────────────────────────────────────────────
FLASK_DEBUG=false
ENABLE_SOCKETIO=true

# ── Optional: Monitoring ───────────────────────────────────────
SENTRY_DSN=
DISCORD_ALERT_WEBHOOK=
WEBHOOK_SECRET=your-webhook-secret-here
BOT_INTERNAL_API_KEY=your-shared-internal-api-key-here
# URL of the bot service for admin guild sync (e.g. https://bot.up.railway.app)
BOT_INTERNAL_URL=
AI_PROVIDER_ENCRYPTION_KEY=base64-encoded-32-byte-key
