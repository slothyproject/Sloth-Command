# Dissident Railway Environment Setup
# Run these commands in Railway dashboard or use Railway CLI

# Required Environment Variables for Backend (dissident-api-backend)
# These must be set in Railway Dashboard: https://railway.app/project/resplendent-fulfillment

# Discord Configuration
DISCORD_CLIENT_ID=1493639167526174830
DISCORD_CLIENT_SECRET=REPLACE_WITH_DISCORD_CLIENT_SECRET
DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN

# JWT Configuration
JWT_SECRET=REPLACE_WITH_JWT_SECRET

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://dissident-website-production.up.railway.app
# Alternative custom domain if configured:
# FRONTEND_URL=https://dissident.mastertibbles.co.uk

# Database (Railway provides this automatically if using Railway Postgres)
# DATABASE_URL will be auto-provisioned

# Node Environment
NODE_ENV=production
PORT=3000

# ============================================
# RAILWAY CLI COMMANDS (Alternative method)
# ============================================
# Uncomment and run these if you have Railway CLI installed:

# railway login
# railway link --project resplendent-fulfillment --service dissident-api-backend
# 
# railway variables set "DISCORD_CLIENT_ID=1493639167526174830"
# railway variables set "DISCORD_CLIENT_SECRET=REPLACE_WITH_DISCORD_CLIENT_SECRET"
# railway variables set "DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN"
# railway variables set "JWT_SECRET=REPLACE_WITH_JWT_SECRET"
# railway variables set "FRONTEND_URL=https://dissident-website-production.up.railway.app"
# railway variables set "NODE_ENV=production"
# railway variables set "PORT=3000"

# ============================================
# VERIFICATION
# ============================================
# After setting variables, redeploy and check health:
# curl https://dissident-api-backend-production.up.railway.app/api/health

# ============================================
# DISCORD OAUTH CONFIGURATION
# ============================================
# Make sure your Discord app's OAuth2 redirect URL is set to:
# https://dissident-api-backend-production.up.railway.app/api/auth/discord/callback
# 
# In Discord Developer Portal:
# 1. Go to https://discord.com/developers/applications/1493639167526174830/oauth2
# 2. Add redirect URL: https://dissident-api-backend-production.up.railway.app/api/auth/discord/callback
# 3. Save changes


